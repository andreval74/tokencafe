RewriteEngine On
RewriteRule ^(favicon\.ico|apple-touch-icon\.png|robots\.txt|sitemap\.xml|manifest\.json|site\.webmanifest)$ - [L]

RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(assets|includes|modules|api)/ - [R=404,L]

RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

RewriteRule ^ index.php [L]
