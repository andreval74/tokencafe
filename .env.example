# ===== TOKENCAFE ENVIRONMENT VARIABLES =====
# Configuração do ecossistema TokenCafe unificado

# ===== APLICAÇÃO =====
NODE_ENV=development
PORT=3000
APP_NAME=TokenCafe
APP_VERSION=1.0.0

# ===== URLS E DOMÍNIOS =====
API_URL=http://localhost:3000/api
FRONTEND_URL=http://localhost:3000
DOMAIN=tokencafe.app

# ===== BLOCKCHAIN CONFIGURATION =====
BLOCKCHAIN_RPC_URL=your_rpc_url_here
DEFAULT_NETWORK=bsc
SUPPORTED_NETWORKS=ethereum,bsc,polygon,arbitrum

# ===== ETHEREUM MAINNET =====
ETHEREUM_RPC_URL=https://mainnet.infura.io/v3/YOUR_INFURA_KEY
ETHEREUM_CHAIN_ID=1

# ===== BSC MAINNET =====
BSC_RPC_URL=https://bsc-dataseed1.binance.org/
BSC_CHAIN_ID=56

# ===== POLYGON MAINNET =====
POLYGON_RPC_URL=https://polygon-rpc.com/
POLYGON_CHAIN_ID=137

# ===== DATABASE =====
DB_HOST=localhost
DB_PORT=5432
DB_NAME=tokencafe_db
DB_USER=tokencafe_user
DB_PASSWORD=your_secure_password_here

# ===== REDIS (CACHE) =====
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_here

# ===== JWT AUTHENTICATION =====
JWT_SECRET=your_very_secure_jwt_secret_key_here
JWT_EXPIRES_IN=24h

# ===== API KEYS =====
INFURA_PROJECT_ID=your_infura_project_id_here
ALCHEMY_API_KEY=your_alchemy_api_key_here
MORALIS_API_KEY=your_moralis_api_key_here

# ===== EMAIL SERVICE =====
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_email_password_here

# ===== STORAGE =====
UPLOAD_PATH=uploads/
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,image/webp

# ===== SECURITY =====
SESSION_SECRET=your_session_secret_key_here
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ===== LOGGING =====
LOG_LEVEL=info
LOG_FILE_PATH=logs/tokencafe.log

# ===== FEATURES FLAGS =====
ENABLE_ANALYTICS=true
ENABLE_WEBHOOKS=true
ENABLE_ADMIN_PANEL=true
ENABLE_WIDGET_CREATOR=true

# ===== COFFEE THEME =====
THEME_NAME=tokencafe
THEME_PRIMARY_COLOR=#8B4513
THEME_SECONDARY_COLOR=#A0522D